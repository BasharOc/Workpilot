# ================================================================
# Production Environment Variables – task-manager (WorkPilot)
# Kopiere diese Datei: cp .env.example .env
# Fülle alle Werte aus, bevor du den Stack startest.
# NIEMALS die .env Datei in Git committen!
# ================================================================

# ── Datenbank ──────────────────────────────────────────────────
POSTGRES_PASSWORD=ersetze_mit_starkem_passwort

# ── JWT Secrets (niemals wiederverwenden!) ─────────────────────
# Neue Geheimnisse generieren: openssl rand -base64 48
JWT_ACCESS_SECRET=ersetze_mit_starkem_zufallswert
JWT_REFRESH_SECRET=ersetze_mit_anderem_starken_zufallswert
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── URLs (Production) ──────────────────────────────────────────
CLIENT_URL=https://workpilot.basharfarhat.com
SERVER_URL=https://workpilot.basharfarhat.com

# ── E-Mail (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=WorkPilot <noreply@basharfarhat.com>

# ── Google OAuth (optional) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://workpilot.basharfarhat.com/api/auth/google/callback
GOOGLE_FRONTEND_CALLBACK_URL=https://workpilot.basharfarhat.com/auth/google/callback
